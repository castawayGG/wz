{
  "name": "Warzone Sniper",
  "description": "Low-sensitivity sniper profile. Slow tracking, precise long-range shots. Recommended for 800 DPI.",
  "target_game": "cod.exe",
  "version": "1.0",
  "sensitivity": {
    "x": 8.0,
    "y": 7.0,
    "ads_multiplier": 0.35,
    "hipfire_boost": 1.2
  },
  "curve": {
    "type": "s_curve",
    "steepness": 5.0,
    "p1": [0.2, 0.05],
    "p2": [0.8, 0.95]
  },
  "dead_zone": {
    "inner": 0.08,
    "outer": 0.95,
    "type": "circular"
  },
  "smoothing": {
    "enabled": true,
    "alpha": 0.2
  },
  "anti_jitter": {
    "enabled": true,
    "threshold": 3
  },
  "auto_center": {
    "enabled": true,
    "decay_ms": 80
  },
  "left_stick": {
    "ramp_up_ms": 50,
    "walk_modifier_key": "LAlt",
    "walk_deflection": 0.4,
    "diagonal_normalize": true
  },
  "bindings": {
    "W":          { "action": "left_stick_up",    "gamepad_button": 0, "trigger_axis": 0 },
    "A":          { "action": "left_stick_left",  "gamepad_button": 0, "trigger_axis": 0 },
    "S":          { "action": "left_stick_down",  "gamepad_button": 0, "trigger_axis": 0 },
    "D":          { "action": "left_stick_right", "gamepad_button": 0, "trigger_axis": 0 },
    "Space":      { "action": "button",           "gamepad_button": 4096,  "trigger_axis": 0, "comment": "A - Jump" },
    "C":          { "action": "button",           "gamepad_button": 8192,  "trigger_axis": 0, "comment": "B - Crouch/Slide" },
    "LShift":     { "action": "button",           "gamepad_button": 64,    "trigger_axis": 0, "comment": "LS - Sprint" },
    "LCtrl":      { "action": "button",           "gamepad_button": 128,   "trigger_axis": 0, "comment": "RS - Melee" },
    "R":          { "action": "button",           "gamepad_button": 16384, "trigger_axis": 0, "comment": "X - Reload" },
    "F":          { "action": "button",           "gamepad_button": 32768, "trigger_axis": 0, "comment": "Y - Killstreak" },
    "G":          { "action": "button",           "gamepad_button": 256,   "trigger_axis": 0, "comment": "LB - Tactical" },
    "Q":          { "action": "button",           "gamepad_button": 512,   "trigger_axis": 0, "comment": "RB - Lethal" },
    "Tab":        { "action": "button",           "gamepad_button": 32,    "trigger_axis": 0, "comment": "Back - Scoreboard" },
    "Escape":     { "action": "button",           "gamepad_button": 16,    "trigger_axis": 0, "comment": "Start - Pause" },
    "1":          { "action": "button",           "gamepad_button": 4,     "trigger_axis": 0, "comment": "DPAD_LEFT - Slot 1" },
    "2":          { "action": "button",           "gamepad_button": 8,     "trigger_axis": 0, "comment": "DPAD_RIGHT - Slot 2" },
    "LMB":        { "action": "trigger",          "gamepad_button": 0,     "trigger_axis": 2, "comment": "RT - Fire" },
    "RMB":        { "action": "trigger",          "gamepad_button": 0,     "trigger_axis": 1, "comment": "LT - ADS" },
    "ScrollUp":   { "action": "button",           "gamepad_button": 1,     "trigger_axis": 0, "comment": "DPAD_UP" },
    "ScrollDown": { "action": "button",           "gamepad_button": 2,     "trigger_axis": 0, "comment": "DPAD_DOWN" },
    "Mouse4":     { "action": "button",           "gamepad_button": 256,   "trigger_axis": 0, "comment": "LB - Ping" },
    "Mouse5":     { "action": "button",           "gamepad_button": 4096,  "trigger_axis": 0, "comment": "A - Jump" }
  },
  "layers": [
    {
      "name": "ADS",
      "trigger_key": "RMB",
      "sensitivity_multiplier": 0.35,
      "overrides": {}
    }
  ],
  "macros": [
    {
      "name": "quick_scope",
      "trigger_key": "Mouse4",
      "steps": [
        { "button": "LT",  "action": "press",   "delay_ms": 0   },
        { "button": "RT",  "action": "press",   "delay_ms": 120 },
        { "button": "RT",  "action": "release",  "delay_ms": 50  },
        { "button": "LT",  "action": "release",  "delay_ms": 0   }
      ]
    }
  ],
  "hotkeys": {
    "toggle_mode":    "F9",
    "cycle_profile":  "F10",
    "emergency_stop": "F12",
    "toggle_osd":     "F8"
  }
}
